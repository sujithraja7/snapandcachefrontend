{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "officer-dashboard/dist",
  "functions": {
    "backend/api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/officer-dashboard/dist/index.html",
      "status": 200
    }
  ]
}
