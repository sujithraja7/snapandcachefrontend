{
  "version": 2,
  "buildCommand": "cd website && npm install",
  "outputDirectory": "website",
  "public": "website",
  "functions": {
    "backend/api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/website/index.html",
      "status": 200
    }
  ]
}
